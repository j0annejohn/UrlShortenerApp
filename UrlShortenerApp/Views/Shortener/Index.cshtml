@model IEnumerable<UrlShortenerApp.Models.ShortenedLink>

@{
    ViewData["Title"] = "URL Management";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-dark">URL Management System</h1>
        <p class="text-muted">Generate and track shortened links</p>
    </div>

    <div class="card border-0 shadow-sm mb-5 bg-light">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div class="input-group input-group-lg">
                    <input type="url" name="originalUrl" class="form-control border-secondary" placeholder="Enter destination URL here..." required>
                    <button class="btn btn-dark px-4" type="submit">Create Short Link</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white py-3">
            <h5 class="mb-0">Link Registry</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th class="ps-4">Original URL</th>
                            <th>Short Link</th>
                            <th class="text-center">Total Visits</th>
                            <th class="pe-4">Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-truncate ps-4" style="max-width: 300px;">@item.OriginalUrl</td>
                                    <td>
                                        <a href="/s/@item.ShortCode" target="_blank" class="text-secondary fw-bold text-decoration-none">
                                            @Context.Request.Host/s/@item.ShortCode
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary px-3">@item.ClickCount</span>
                                    </td>
                                    <td class="text-muted small pe-4">@item.CreatedAt.ToString("dd-MM-yyyy")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">No links found in the registry.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>