@model IEnumerable<UrlShortenerApp.Models.ShortenedLink>

@{
    ViewData["Title"] = "URL Management";
}

<div class="container-fluid mt-5 px-4">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm bg-dark text-white p-4" style="border-radius: 12px;">
                <h2 class="h4 fw-bold mb-3">Create Link</h2>
                <p class="text-secondary small mb-4">Paste a destination URL to generate a new short code for the registry.</p>
                
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        @* Fixed the opacity and text color for the input *@
                        <input type="url" name="originalUrl" class="form-control border-0 bg-secondary text-white py-2"
                               placeholder="https://example.com" required style="background-color: rgba(255,255,255,0.1) !important;">
                    </div>
                    <button class="btn btn-light w-100 fw-bold py-2" type="submit">Create Short Link</button>
                </form>
            </div>

            <div class="card border-0 shadow-sm mt-3 p-3 bg-light" style="border-radius: 12px;">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted small fw-bold">TOTAL LINKS</span>
                    <span class="h4 mb-0 fw-bold text-dark">@Model?.Count()</span>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold text-dark">Link Registry</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4 border-0 text-muted small">DESTINATION</th>
                                <th class="border-0 text-muted small">SHORT LINK</th>
                                <th class="text-center border-0 text-muted small">VISITS</th>
                                <th class="pe-4 border-0 text-muted small">DATE</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="text-truncate text-dark fw-medium" style="max-width: 250px;" title="@item.OriginalUrl">
                                                @item.OriginalUrl
                                            </div>
                                        </td>
                                        <td>
                                            <a href="/s/@item.ShortCode" target="_blank" class="text-secondary fw-bold text-decoration-none">
                                                /@item.ShortCode
                                            </a>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary px-3">@item.ClickCount</span>
                                        </td>
                                        <td class="text-muted small pe-4">@item.CreatedAt.ToString("dd MMM")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted">No links in registry.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>